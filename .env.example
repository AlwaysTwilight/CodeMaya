# Server
PORT=3000

# Chroma
# If you're running chroma locally (recommended for dev):
# docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=codemaya_docs
CHROMA_TENANT=codemaya_tenant
CHROMA_DATABASE=codemaya_db

# Embeddings
# Choose: "offline" (no keys) or "hf" (Hugging Face Inference API).
#EMBEDDINGS_PROVIDER=offline

# Offline embeddings (no downloads, no API keys).
#EMBEDDINGS_DIM=512

# Hugging Face Inference embeddings (requires HF_TOKEN).
# Example model: BAAI/bge-large-en
HF_TOKEN=
HF_EMBEDDINGS_MODEL=BAAI/bge-large-en

# Seeding
DOCS_DIR=./data/docs
CHUNK_MIN_CHARS=300
CHUNK_MAX_CHARS=1500
SEMANTIC_BREAKPOINT_THRESHOLD=0.55
SEED_BATCH_SIZE=64
